{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gf-framework.dev/schemas/project-snapshot-v2.json",
  "title": "GF Observed Project Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generator_version",
    "generated_at_utc",
    "project_root",
    "contract",
    "framework",
    "project",
    "agents",
    "drift"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 2},
    "generator_version": {"type": "string", "minLength": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_root": {"type": "string", "const": "."},
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "valid", "sha256", "issue_count"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "valid": {"type": "boolean"},
        "sha256": {"type": "string", "pattern": "^$|^[0-9a-f]{64}$"},
        "issue_count": {"type": "integer", "minimum": 0}
      }
    },
    "framework": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "installed",
        "version",
        "catalog_framework_version",
        "catalog_matches_framework",
        "plugin_enabled",
        "packages",
        "package_state",
        "extensions"
      ],
      "properties": {
        "installed": {"type": "boolean"},
        "version": {"type": "string"},
        "catalog_framework_version": {"type": "string", "minLength": 1},
        "catalog_matches_framework": {"type": "boolean"},
        "plugin_enabled": {"type": "boolean"},
        "packages": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "package_state": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "lockfile_present", "valid", "issues"],
          "properties": {
            "source": {"type": "string", "enum": ["filesystem", "lockfile"]},
            "lockfile_present": {"type": "boolean"},
            "valid": {"type": "boolean"},
            "issues": {"type": "array", "items": {"type": "string"}}
          }
        },
        "extensions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["godot_features", "script_count", "test_script_count", "source_scan_truncated", "gf_api_usage", "declared_roots", "module_dependency_analysis"],
      "properties": {
        "godot_features": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "script_count": {"type": "integer", "minimum": 0},
        "test_script_count": {"type": "integer", "minimum": 0},
        "source_scan_truncated": {"type": "boolean"},
        "gf_api_usage": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "declared_roots": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["module_id", "path", "exists"],
            "properties": {
              "module_id": {"type": "string"},
              "path": {"type": "string"},
              "exists": {"type": "boolean"}
            }
          }
        },
        "module_dependency_analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "complete",
            "truncated",
            "supported_extensions",
            "scanned_file_count",
            "scanned_byte_count",
            "oversized_file_count",
            "unreadable_file_count",
            "missing_root_count",
            "unsafe_path_count",
            "unowned_reference_count",
            "unowned_references_truncated",
            "unowned_references",
            "module_file_counts",
            "ambiguous_class_name_count",
            "ambiguous_class_names_truncated",
            "ambiguous_class_names",
            "edges",
            "cycles"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_configured", "contract_invalid", "complete", "incomplete", "truncated"]
            },
            "complete": {"type": "boolean"},
            "truncated": {"type": "boolean"},
            "supported_extensions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "pattern": "^\\.[a-z]+$"}
            },
            "scanned_file_count": {"type": "integer", "minimum": 0},
            "scanned_byte_count": {"type": "integer", "minimum": 0},
            "oversized_file_count": {"type": "integer", "minimum": 0},
            "unreadable_file_count": {"type": "integer", "minimum": 0},
            "missing_root_count": {"type": "integer", "minimum": 0},
            "unsafe_path_count": {"type": "integer", "minimum": 0},
            "unowned_reference_count": {"type": "integer", "minimum": 0},
            "unowned_references_truncated": {"type": "boolean"},
            "unowned_references": {
              "type": "array",
              "maxItems": 100,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_path", "target_path", "line"],
                "properties": {
                  "source_path": {"type": "string", "pattern": "^res://.+$"},
                  "target_path": {"type": "string", "pattern": "^res://.+$"},
                  "line": {"type": "integer", "minimum": 1}
                }
              }
            },
            "module_file_counts": {
              "type": "array",
              "maxItems": 120,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["module_id", "file_count", "class_name_count"],
                "properties": {
                  "module_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
                  "file_count": {"type": "integer", "minimum": 0},
                  "class_name_count": {"type": "integer", "minimum": 0}
                }
              }
            },
            "ambiguous_class_name_count": {"type": "integer", "minimum": 0},
            "ambiguous_class_names_truncated": {"type": "boolean"},
            "ambiguous_class_names": {
              "type": "array",
              "maxItems": 100,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["class_name", "paths"],
                "properties": {
                  "class_name": {"type": "string", "minLength": 1},
                  "paths": {
                    "type": "array",
                    "minItems": 2,
                    "uniqueItems": true,
                    "items": {"type": "string", "pattern": "^res://.+$"}
                  }
                }
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_module", "target_module", "reference_count", "kinds", "evidence_truncated", "evidence"],
                "properties": {
                  "source_module": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
                  "target_module": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
                  "reference_count": {"type": "integer", "minimum": 1},
                  "kinds": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"type": "string", "enum": ["class_name", "resource_path"]}
                  },
                  "evidence_truncated": {"type": "boolean"},
                  "evidence": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 12,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["source_path", "target_path", "kind", "symbol", "line"],
                      "properties": {
                        "source_path": {"type": "string", "pattern": "^res://.+$"},
                        "target_path": {"type": "string", "pattern": "^res://.+$"},
                        "kind": {"type": "string", "enum": ["class_name", "resource_path"]},
                        "symbol": {"type": "string", "minLength": 1},
                        "line": {"type": "integer", "minimum": 1}
                      }
                    }
                  }
                }
              }
            },
            "cycles": {
              "type": "array",
              "items": {
                "type": "array",
                "minItems": 2,
                "uniqueItems": true,
                "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"}
              }
            }
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["installed", "drifted"],
      "properties": {
        "installed": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "drifted": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "drift": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "error_count", "warning_count", "issues"],
      "properties": {
        "ok": {"type": "boolean"},
        "error_count": {"type": "integer", "minimum": 0},
        "warning_count": {"type": "integer", "minimum": 0},
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["severity", "code", "path", "message"],
            "properties": {
              "severity": {"type": "string", "enum": ["error", "warning"]},
              "code": {"type": "string"},
              "path": {"type": "string"},
              "message": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
