{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gf-framework.dev/schemas/capability-catalog-v1.json",
  "title": "GF Capability Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_version", "capabilities"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "catalog_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "capabilities": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "summary", "keywords", "packages", "primary_classes", "recipes", "boundary"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$", "maxLength": 120},
          "title": {"type": "string", "minLength": 1, "maxLength": 160},
          "summary": {"type": "string", "minLength": 1, "maxLength": 600},
          "keywords": {
            "type": "array",
            "minItems": 1,
            "maxItems": 40,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1, "maxLength": 80}
          },
          "packages": {
            "type": "array",
            "minItems": 1,
            "maxItems": 30,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^gf\\.[a-z0-9_.-]+$", "maxLength": 160}
          },
          "primary_classes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 40,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^GF[A-Za-z0-9_]+$", "maxLength": 200}
          },
          "recipes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 30,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$", "maxLength": 120}
          },
          "boundary": {"type": "string", "minLength": 1, "maxLength": 600}
        }
      }
    }
  }
}
