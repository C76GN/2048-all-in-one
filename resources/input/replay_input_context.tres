[sub_resource type="Resource" id="Action_replay_prev_step"]
script = ExtResource("2_action")
action_id = &"replay_prev_step"
display_name = "Replay Previous Step"
display_category = "Replay"

[sub_resource type="InputEventKey" id="Key_replay_prev_a"]
physical_keycode = 65

[sub_resource type="Resource" id="Binding_replay_prev_a"]
script = ExtResource("3_binding")
input_event = SubResource("Key_replay_prev_a")
display_name = "A"

[sub_resource type="InputEventKey" id="Key_replay_prev_left"]
keycode = 4194319

[sub_resource type="Resource" id="Binding_replay_prev_left"]
script = ExtResource("3_binding")
input_event = SubResource("Key_replay_prev_left")
display_name = "Left"

[sub_resource type="InputEventJoypadButton" id="Joy_replay_prev_dpad"]
