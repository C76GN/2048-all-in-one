button_index = 13

[sub_resource type="Resource" id="Binding_replay_prev_dpad"]
script = ExtResource("3_binding")
input_event = SubResource("Joy_replay_prev_dpad")
display_name = "D-pad Left"

[sub_resource type="InputEventJoypadMotion" id="Joy_replay_prev_axis"]
device = -1
axis = 0
axis_value = -1.0

[sub_resource type="Resource" id="Binding_replay_prev_axis"]
script = ExtResource("3_binding")
input_event = SubResource("Joy_replay_prev_axis")
value_target = 3
deadzone = 0.5
display_name = "Left Stick Left"

[sub_resource type="Resource" id="Mapping_replay_prev_step"]
script = ExtResource("4_mapping")
action = SubResource("Action_replay_prev_step")
bindings = Array[ExtResource("3_binding")]([SubResource("Binding_replay_prev_a"), SubResource("Binding_replay_prev_left"), SubResource("Binding_replay_prev_dpad"), SubResource("Binding_replay_prev_axis")])

