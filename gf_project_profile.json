{
  "schema_version": 1,
  "id": "c76.2048.gf_module_layered.v1",
  "display_name": "2048 GF Module-Layered Project Layout",
  "description": "Strict project layout for the GF sample: composition, runtime modules, content, tests, and tooling remain explicit.",
  "zones": [
    {
      "id": "framework",
      "description": "Vendored framework and editor plugins.",
      "roots": ["addons"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "runtime",
      "description": "GF Models, Systems, Utilities, Controllers, rules, and application boot code.",
      "roots": ["scripts"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "presentation",
      "description": "Godot scenes and runtime resources.",
      "roots": ["scenes", "resources"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "asset_library",
      "description": "Audited reusable assets and candidate review records.",
      "roots": ["asset_library"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "quality",
      "description": "Automated tests, maintenance tools, and architecture documentation.",
      "roots": ["tests", "tools", "docs"],
      "required": true,
      "severity": "error"
    }
  ],
  "rules": [
    {
      "id": "root_files_are_declared",
      "description": "Keep project root intentional and review every new root-level file.",
      "kind": "forbid_root_files",
      "allowed_files": [
        "project.godot",
        ".editorconfig",
        ".gitattributes",
        ".gitignore",
        "AI_MAINTENANCE.md",
        "CODING_STYLE.md",
        "README.md",
        "export_presets.cfg",
        "gf_project_profile.json",
        "icon.svg",
        "icon.svg.import",
        "repomix-output.txt",
        "repomix.config.json"
      ],
      "severity": "error"
    },
    {
      "id": "runtime_paths_are_snake_case",
      "description": "Runtime-facing project paths remain portable across case-sensitive exported builds.",
      "kind": "naming_convention",
      "roots": ["scripts", "scenes", "resources", "tests", "tools"],
      "exclude": ["**/*.uid", "**/*.import"],
      "pattern": "^[a-z0-9_./-]+$",
      "target": "path",
      "severity": "error"
    },
    {
      "id": "generated_files_stay_in_generated_roots",
      "description": "Generated source and resources must remain in explicit generated roots.",
      "kind": "generated_boundary",
      "include": ["**/*.generated.*", "**/generated/**"],
      "roots": ["build", ".godot", "gf/generated"],
      "severity": "error"
    },
    {
      "id": "module_buckets_have_growth_budgets",
      "description": "Large type buckets are bounded so new cohesive modules are introduced before locality degrades.",
      "kind": "bucket_size",
      "roots": ["scripts", "resources", "scenes"],
      "max_files": 240,
      "severity": "warning"
    }
  ],
  "metadata": {
    "architecture": "gf_module_layered",
    "stage": "v1",
    "warnings_are_failures": true
  }
}
