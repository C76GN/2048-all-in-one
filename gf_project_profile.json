{
  "schema_version": 1,
  "id": "c76.2048.feature_cohesive.v1",
  "display_name": "2048 GF Feature-Cohesive Project Layout",
  "description": "Strict project profile derived from GF's built-in Feature-Cohesive layout.",
  "zones": [
    {
      "id": "app",
      "description": "Composition root, boot scene, installer, and application entry points.",
      "roots": ["app"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "features",
      "description": "Cohesive business features that own their scripts, scenes, resources, docs, and local tools.",
      "roots": ["features"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "shared",
      "description": "Deliberately cross-feature contracts, foundations, UI primitives, resources, and utilities.",
      "roots": ["shared"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "tests",
      "description": "Cross-feature contract, integration, and regression tests.",
      "roots": ["tests"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "project_support",
      "description": "Project-wide documentation and automation tools.",
      "roots": ["docs", "tools"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "framework",
      "description": "Vendored GF and test add-ons.",
      "roots": ["addons"],
      "required": true,
      "severity": "error"
    },
    {
      "id": "generated",
      "description": "Generated source and reproducible intermediate output.",
      "roots": ["generated"],
      "severity": "error"
    }
  ],
  "rules": [
    {
      "id": "root_files_are_declared",
      "description": "Keep the project root intentional; runtime content belongs to app, features, or shared.",
      "kind": "forbid_root_files",
      "allowed_files": [
        "project.godot",
        ".editorconfig",
        ".env",
        ".gitattributes",
        ".gitignore",
        ".repomixignore",
        "README.md",
        "LICENSE",
        "LICENSE.md",
        "default_bus_layout.tres",
        "export_presets.cfg",
        "gf_project_profile.json",
        "icon.svg",
        "icon.svg.import",
        "repomix-output.txt",
        "repomix.config.json"
      ],
      "severity": "error"
    },
    {
      "id": "project_paths_are_snake_case",
      "description": "Hand-authored project paths use stable lowercase snake_case names.",
      "kind": "naming_convention",
      "roots": ["app", "features", "shared", "generated", "tests", "tools", "docs"],
      "exclude": [
        "**/*.uid",
        "**/*.import",
        "features/asset_library/resources/source_packs/**"
      ],
      "pattern": "^[a-z0-9_./-]+$",
      "target": "path",
      "severity": "error"
    },
    {
      "id": "features_are_inner_cohesive",
      "description": "Each feature owns its scripts and may only expose standard Feature-Cohesive subdirectories.",
      "kind": "feature_module_contract",
      "roots": ["features"],
      "feature_id_pattern": "^[a-z][a-z0-9_]*$",
      "required_subdirs": ["scripts"],
      "allowed_subdirs": ["scripts", "scenes", "resources", "tests", "docs", "tools"],
      "allow_root_files": false,
      "severity": "error"
    },
    {
      "id": "generated_files_stay_in_generated_roots",
      "description": "Generated files stay in generated instead of leaking into hand-authored modules.",
      "kind": "generated_boundary",
      "include": ["**/*.generated.*", "**/generated/**"],
      "roots": ["generated"],
      "severity": "error"
    },
    {
      "id": "legacy_type_buckets_are_empty",
      "description": "Legacy global type buckets are migration-only and may not regain project files.",
      "kind": "bucket_size",
      "roots": ["scripts", "scenes", "resources", "assets", "asset_library"],
      "max_files": 1,
      "severity": "error"
    }
  ],
  "metadata": {
    "layout": "feature_cohesive",
    "base_profile": "gf.project_layout.feature_cohesive.v1",
    "stage": "v1",
    "warnings_are_failures": true
  }
}
