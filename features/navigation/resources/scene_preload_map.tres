[gd_resource type="Resource" script_class="GFScenePreloadMap" load_steps=8 format=3]

[ext_resource type="Script" path="res://addons/gf/standard/utilities/scene/gf_scene_preload_map.gd" id="1_map"]
[ext_resource type="Script" path="res://addons/gf/standard/utilities/scene/gf_scene_preload_entry.gd" id="2_entry"]

[sub_resource type="Resource" id="Entry_main_menu"]
script = ExtResource("2_entry")
scene_path = "res://features/navigation/scenes/menus/main_menu.tscn"
adjacent_scene_paths = PackedStringArray("res://features/navigation/scenes/menus/mode_selection.tscn")
fixed = true
metadata = {"role": "hub"}

[sub_resource type="Resource" id="Entry_mode_selection"]
script = ExtResource("2_entry")
scene_path = "res://features/navigation/scenes/menus/mode_selection.tscn"
adjacent_scene_paths = PackedStringArray("res://features/navigation/scenes/menus/main_menu.tscn", "res://features/gameplay/scenes/game/game_play.tscn")
metadata = {"role": "game_setup"}

[sub_resource type="Resource" id="Entry_gameplay"]
script = ExtResource("2_entry")
scene_path = "res://features/gameplay/scenes/game/game_play.tscn"
adjacent_scene_paths = PackedStringArray("res://features/navigation/scenes/menus/mode_selection.tscn", "res://features/settings/scenes/menus/settings_menu.tscn")
metadata = {"role": "gameplay"}

[sub_resource type="Resource" id="Entry_bookmarks"]
script = ExtResource("2_entry")
scene_path = "res://features/bookmarks/scenes/menus/bookmark_list.tscn"
adjacent_scene_paths = PackedStringArray("res://features/navigation/scenes/menus/main_menu.tscn", "res://features/gameplay/scenes/game/game_play.tscn")
metadata = {"role": "collection"}

[sub_resource type="Resource" id="Entry_replays"]
script = ExtResource("2_entry")
scene_path = "res://features/replays/scenes/menus/replay_list.tscn"
adjacent_scene_paths = PackedStringArray("res://features/navigation/scenes/menus/main_menu.tscn", "res://features/gameplay/scenes/game/game_play.tscn")
metadata = {"role": "collection"}

[sub_resource type="Resource" id="Entry_settings"]
script = ExtResource("2_entry")
scene_path = "res://features/settings/scenes/menus/settings_menu.tscn"
adjacent_scene_paths = PackedStringArray("res://features/navigation/scenes/menus/main_menu.tscn", "res://features/gameplay/scenes/game/game_play.tscn")
metadata = {"role": "settings"}

[resource]
script = ExtResource("1_map")
default_radius = 1
max_scheduled_scenes = 2
fixed_scene_paths = PackedStringArray("res://features/navigation/scenes/menus/main_menu.tscn")
entries = Array[ExtResource("2_entry")]([SubResource("Entry_main_menu"), SubResource("Entry_mode_selection"), SubResource("Entry_gameplay"), SubResource("Entry_bookmarks"), SubResource("Entry_replays"), SubResource("Entry_settings")])
metadata = {"feature": "navigation", "purpose": "runtime_scene_warmup"}
